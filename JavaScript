document.addEventListener("DOMContentLoaded", function () {
  // Normalize current path: remove trailing slash, treat root as / or /index.html equivalently
  const currentPath = (window.location.pathname.replace(/\/$/, '')) || '/';

  document.querySelectorAll(".menu-item").forEach(function (menu) {
    const href = menu.getAttribute("href");
    if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;

    // Build an absolute URL from the href so we can reliably read its pathname
    let linkPath;
    try {
      linkPath = new URL(href, window.location.origin).pathname.replace(/\/$/, '') || '/';
    } catch (e) {
      // If URL construction fails, skip this item
      return;
    }

    // Treat / and /index.html (or index.html) as equivalent
    const indexEquivalents = new Set(['/', '/index.html', '/index.htm']);
    if (linkPath === currentPath ||
        (indexEquivalents.has(linkPath) && indexEquivalents.has(currentPath))) {
      menu.classList.add("active");
    } else {
      menu.classList.remove("active");
    }
  });
});
